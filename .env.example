FAKA_LISTEN=:8080
FAKA_DB=/app/data/data.db
SESSION_SECRET=change-me-to-random
COOKIE_SECURE=true   # 生产(HTTPS)保持 true;本地 HTTP 调试需设 false,否则浏览器不保存登录 cookie

# 支付密钥主密钥:用于加密存储支付宝/微信的私钥、APIv3 密钥等敏感配置。
# 必须是 32 字节 或 64 位十六进制字符。务必随机生成并妥善保管:
#   openssl rand -hex 32
# 换机器/重新部署时必须用同一值,否则已加密的密钥无法解密。
PAY_SECRET=change-me-to-32-random-bytes

# 仅首次启动创建第一个管理员(创建后可移除)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
# 其余配置(NewAPI 网址/令牌/用户ID、SMTP、支付宝/微信官方凭证)在后台 /admin/config 页面填写
